# ==========================================
# joto-bot («Article Generator») — переменные окружения
# ==========================================
# Скопируй в .env (локально) или задай в Railway → Variables.

# --- База данных (Postgres) ---
# Railway создаёт её автоматически при добавлении плагина PostgreSQL.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# --- Wildberries ---
# JWT-токен из ЛК продавца → Доступ к API.
# Для мониторинга CTR нужна категория «Статистика»/«Аналитика»,
# для раздела «Массовые карточки WB» — категория «Контент».
WB_API_TOKEN=eyJhbGciOiJI...

# --- Национальный каталог (Честный ЗНАК) — Вариант Б: создание ГТИНов ---
# Получаются в ЛК «Честный ЗНАК»: товарная группа → Помощь → API → «API Национального каталога».
# NK_API_KEY — apikey (постоянный ключ доступа НК).
NK_API_KEY=
# NK_PARTY_ID — идентификатор владельца товара (party_id / suppliers_id).
NK_PARTY_ID=
# NK_BASE_URL — базовый URL API НК (сверьте с документацией в ЛК). По умолчанию:
# NK_BASE_URL=https://api.national-catalog.ru

# --- Bitrix24: локальное приложение (OAuth) ---
# Создаётся в Bitrix24 → Разработчикам → Другое → Локальное приложение.
# CLIENT_ID в формате local.xxxxxxxx.xxxxxxxx
BITRIX_CLIENT_ID=local.xxxxxxxxxxxxxx.xxxxxxxx
# CLIENT_SECRET того же приложения — нужен для обновления access_token.
BITRIX_CLIENT_SECRET=
# Application token (приходит в каждом событии). Заполнять не обязательно —
# если задан, бот будет проверять подпись входящих событий.
BITRIX_APP_TOKEN=
# Домен портала Битрикс24 для REST-вызовов. Запасной вариант на случай, если в
# OAuth сохранился oauth.bitrix.info (его Битрикс отдаёт в ответе refresh-токена).
BITRIX_PORTAL_DOMAIN=joto.bitrix24.ru

# --- Публичный адрес приложения на Railway ---
# Куда Bitrix24 шлёт события бота. Это домен сервиса на Railway.
# События приходят на {PUBLIC_BASE_URL}/bitrix/events
PUBLIC_BASE_URL=https://joto-bot-production.up.railway.app

# --- Получатели уведомлений в Битриксе ---
# Bitrix user ID, которому слать ежедневный отчёт по задачам.
REPORT_USER_ID=226
# DIALOG_ID чата для алертов по падению CTR (например chatXXXX или ID пользователя).
CTR_ALERT_DIALOG=chat2024

# --- Сезонная распродажа (отчёт по распродаже) ---
# Кому слать отчёт по распродаже. Можно указать:
#   • имя сотрудника (ищется в Битриксе) — например, Татьяна;
#   • ID пользователя (число) — придёт в личку;
#   • чат (chatXXXX) — придёт в чат (бот должен быть участником чата).
# По умолчанию — лично Татьяне.
SEASON_REPORT_TO=Татьяна
# DIALOG_ID чата «Отдел продаж» (используется как «тихий» чат: бот туда не пишет
# по артикулам). Оставлен для совместимости/алертов.
SALES_DEPT_DIALOG=chat2024
# Категория для еженедельного авто-отчёта (10 — шорты, 11 — футболки, 05 — худи, 02 — куртки).
SEASON_REPORT_CATEGORY=10
# Дата конца сезона (YYYY-MM-DD) — относительно неё считается, успеваем ли распродать.
SEASON_END_DATE=2026-08-31
# Маржа: себестоимость как доля от обычной цены (0..1) и минимальная наценка к ней.
# Ограничивают максимально возможную скидку, чтобы распродажа не уходила ниже маржи.
# Пример: себест. 0.35 + маржа 0.10 → макс скидка ~62%.
SEASON_COST_SHARE=0.35
SEASON_MIN_MARGIN=0.10
